# ---------------------------------------------------------------------------
# PalmInsight environment configuration
# Copy to .env.local and fill in. The app runs fully WITHOUT any of these
# (mock payment + in-memory store), so you can demo immediately. Add real
# keys to enable production payments and persistence.
# ---------------------------------------------------------------------------

# Public base URL of the deployment (used for checkout redirects + share links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Polar.sh (payments). If unset, the app uses a built-in mock checkout. ---
# Requires BOTH the access token and the product id to go live.
# Organization access token (Polar dashboard → Settings → Developers).
POLAR_ACCESS_TOKEN=
# The Deep Report product id (Polar dashboard → Products).
POLAR_PRODUCT_ID=
# Webhook signing secret (Polar dashboard → Settings → Webhooks). Optional —
# /api/confirm also verifies the checkout directly after redirect.
POLAR_WEBHOOK_SECRET=
# "sandbox" (test) or "production" (live charges). Defaults to sandbox.
POLAR_SERVER=sandbox
# Price label shown in the UI, in the smallest currency unit (cents). Default 500 = $5.
# The actual amount charged is set on the Polar product itself.
PREMIUM_PRICE_CENTS=500
PREMIUM_CURRENCY=usd

# --- Supabase (persistence + image storage). If unset, uses in-memory store. -
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key is used server-side only for trusted writes (never exposed).
SUPABASE_SERVICE_ROLE_KEY=

# Secret used to sign unlock tokens AND auth session/anon cookies.
# Set to a long random string in production (e.g. `openssl rand -hex 32`).
UNLOCK_TOKEN_SECRET=dev-only-change-me

# Comma-separated emails that can access the /admin analytics dashboard.
ADMIN_EMAILS=
